# PostgreSQL local o referencia privada de Railway.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_juarez?schema=public"

# Generar dos valores diferentes de al menos 48 caracteres.
SESSION_SECRET="CAMBIAR-POR-UN-SECRETO-ALEATORIO-DE-64-CARACTERES"
ACCESS_CODE_SECRET="CAMBIAR-POR-OTRO-SECRETO-ALEATORIO-DE-64-CARACTERES"

NEXT_PUBLIC_APP_NAME="LINOEM HOTEL"
NEXT_PUBLIC_COMPANY_NAME="LINOEM DEVELOPMENT"
NODE_ENV="production"
ALLOW_DEMO_SEED="true"

# Crear o actualizar usuarios iniciales en Railway.
# Configura estas variables temporalmente, despliega y después elimina la contraseña.
BOOTSTRAP_ADMIN_EMAIL="admin@linoem.mx"
BOOTSTRAP_ADMIN_PASSWORD="LinoemDemo2026!"
BOOTSTRAP_ADMIN_NAME="Administrador LINOEM"
BOOTSTRAP_BRANCH_CODE="MATRIZ"
